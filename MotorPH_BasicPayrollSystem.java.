import java.io.*;
import java.util.*;

public class MotorPH_BasicPayrollSystem {

    static Scanner sc = new Scanner(System.in);
    static String CSV_FILE = "resources/MotorPH Employee Data - Attendance Record.csv";

    public static void main(String[] args) throws Exception {
        System.out.println("Welcome to MotorPH Basic Payroll System\n");
        System.out.print("Enter username: ");
        String username = sc.nextLine();
        System.out.print("Enter password: ");
        String password = sc.nextLine();

        if (!isValidUser(username, password)) {
            System.out.println("Incorrect username and/or password.");
            System.exit(0);
        }

        if (username.equals("employee")) {
            employeeMenu();
        } else if (username.equals("payroll_staff")) {
            payrollStaffMenu();
        }
    }

    static boolean isValidUser(String u, String p) {
        return (u.equals("employee") || u.equals("payroll_staff")) && p.equals("12345");
    }

    static void employeeMenu() throws Exception {
        System.out.println("\n1. Enter your employee number");
        System.out.println("2. Exit");
        System.out.print("Select: ");
        int choice = Integer.parseInt(sc.nextLine());
        switch (choice) {
            case 1:
                System.out.print("Enter your employee number: ");
                String empNum = sc.nextLine();
                processPayrollForEmployee(empNum);
                break;
            case 2:
                System.out.println("Exiting program...");
                System.exit(0);
        }
    }

    static void payrollStaffMenu() throws Exception {
        System.out.println("\n1. Process Payroll");
        System.out.println("2. Exit");
        System.out.print("Select: ");
        int choice = Integer.parseInt(sc.nextLine());
        switch (choice) {
            case 1:
                System.out.println("\n1. One employee");
                System.out.println("2. All employees");
                System.out.println("3. Exit");
                System.out.print("Select: ");
                int subChoice = Integer.parseInt(sc.nextLine());
                switch (subChoice) {
                    case 1:
                        System.out.print("Enter employee number: ");
                        String empNum = sc.nextLine();
                        processPayrollForEmployee(empNum);
                        break;
                    case 2:
                        processPayrollForAll();
                        break;
                    case 3:
                        System.out.println("Exiting program...");
                        System.exit(0);
                }
                break;
            case 2:
                System.out.println("Exiting program...");
                System.exit(0);
        }
    }

    // ----------------------- PAYROLL CALCULATIONS -----------------------

    static void processPayrollForEmployee(String empNum) throws Exception {
        BufferedReader br = new BufferedReader(new FileReader(CSV_FILE));
        String line;
        boolean found = false;
        List<String[]> records = new ArrayList<>();

        while ((line = br.readLine()) != null) {
            String[] data = line.split(",");
            if (data[0].equals(empNum)) {
                records.add(data);
                found = true;
            }
        }
        br.close();

        if (!found) {
            System.out.println("Employee number does not exist.");
            return;
        }

        System.out.println("\nPayroll for Employee #: " + empNum);
        System.out.println("Name: " + records.get(0)[2] + " " + records.get(0)[1]);
        System.out.println("Birthday: " + records.get(0)[3]);

        // Process each record (cutoff)
        for (String[] data : records) {
            String date = data[5];
            double timeIn = Double.parseDouble(data[6]);
            double timeOut = Double.parseDouble(data[7]);
            double hourlyRate = Double.parseDouble(data[4]);

            double hoursWorked = calculateHours(timeIn, timeOut);
            double grossSalary = hoursWorked * hourlyRate;

            System.out.println("\nCutoff Date: " + date);
            System.out.println("Total Hours Worked: " + hoursWorked);
            System.out.println("Gross Salary: " + grossSalary);

            // Check if this is second cutoff (16–end of month) for deductions
            if (date.endsWith("/16/2024") || date.endsWith("/31/2024") || date.endsWith("/30/2024")) {
                double sss = calculateSSS(grossSalary);
                double philHealth = calculatePhilHealth(grossSalary);
                double pagIbig = calculatePagIbig(grossSalary);
                double totalDeductions = sss + philHealth + pagIbig;
                double tax = calculateWithholdingTax(grossSalary - totalDeductions);
                totalDeductions += tax;

                double netSalary = grossSalary - totalDeductions;

                System.out.println("Deductions:");
                System.out.println("SSS: " + sss);
                System.out.println("PhilHealth: " + philHealth);
                System.out.println("Pag-IBIG: " + pagIbig);
                System.out.println("Tax: " + tax);
                System.out.println("Total Deductions: " + totalDeductions);
                System.out.println("Net Salary: " + netSalary);
            }
        }
    }

    static void processPayrollForAll() throws Exception {
        BufferedReader br = new BufferedReader(new FileReader(CSV_FILE));
        String line;
        Set<String> empSet = new HashSet<>();
        while ((line = br.readLine()) != null) {
            String[] data = line.split(",");
            if (!empSet.contains(data[0])) {
                processPayrollForEmployee(data[0]);
                empSet.add(data[0]);
            }
        }
        br.close();
    }

    // ----------------------- HELPER FUNCTIONS -----------------------

    static double calculateHours(double in, double out) {
        double start = Math.max(in, 8.0);
        double end = Math.min(out, 17.0);
        return Math.max(0, end - start);
    }

    static double calculateSSS(double gross) {
        if (gross < 3250) return 135;
        if (gross < 3750) return 157.5;
        if (gross < 4250) return 180;
        if (gross < 4750) return 202.5;
        if (gross < 5250) return 225;
        if (gross < 5750) return 247.5;
        if (gross < 6250) return 270;
        if (gross < 6750) return 292.5;
        if (gross < 7250) return 315;
        if (gross < 7750) return 337.5;
        if (gross < 8250) return 360;
        if (gross < 8750) return 382.5;
        if (gross < 9250) return 405;
        if (gross < 9750) return 427.5;
        if (gross < 10250) return 450;
        if (gross < 10750) return 472.5;
        if (gross < 11250) return 495;
        if (gross < 11750) return 517.5;
        if (gross < 12250) return 540;
        if (gross < 12750) return 562.5;
        if (gross < 13250) return 585;
        if (gross < 13750) return 607.5;
        if (gross < 14250) return 630;
        if (gross < 14750) return 652.5;
        if (gross < 15250) return 675;
        if (gross < 15750) return 697.5;
        if (gross < 16250) return 720;
        if (gross < 16750) return 742.5;
        if (gross < 17250) return 765;
        if (gross < 17750) return 787.5;
        if (gross < 18250) return 810;
        if (gross < 18750) return 832.5;
        if (gross < 19250) return 855;
        if (gross < 19750) return 877.5;
        if (gross < 20250) return 900;
        if (gross < 20750) return 922.5;
        if (gross < 21250) return 945;
        if (gross < 21750) return 967.5;
        if (gross < 22250) return 990;
        if (gross < 22750) return 1012.5;
        if (gross < 23250) return 1035;
        if (gross < 23750) return 1057.5;
        if (gross < 24250) return 1080;
        if (gross < 24750) return 1102.5;
        return 1125;
    }

    static double calculatePhilHealth(double gross) {
        double premium = gross * 0.03;
        return premium / 2; // employee share
    }

    static double calculatePagIbig(double gross) {
        if (gross <= 1500) return gross * 0.01;
        else return gross * 0.02;
    }

    static double calculateWithholdingTax(double taxable) {
        if (taxable <= 20832) return 0;
        else if (taxable <= 33332) return (taxable - 20833) * 0.2;
        else if (taxable <= 66666) return 2500 + (taxable - 33333) * 0.25;
        else if (taxable <= 166666) return 10833 + (taxable - 66667) * 0.3;
        else if (taxable <= 666666) return 40833.33 + (taxable - 166667) * 0.32;
        else return 200833.33 + (taxable - 666667) * 0.35;
    }
}
